<?xml version="1.0" encoding="utf-8"?>
<!--
  Pre-Android 12 backup configuration. Mirrors data_extraction_rules.xml's
  exclusion list — same rationale: PAT lives in EncryptedSharedPreferences
  keyed by AndroidKeystore master key, which is non-transferable.
  Restoring app state to a different device would leave the user with an
  unrecoverable secret. Excluding everything keeps the backup pipeline
  honest. Used via android:fullBackupContent in AndroidManifest.xml.
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
