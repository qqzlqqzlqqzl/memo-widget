<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:name=".MemoApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/full_backup_content"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MemoWidget">

        <!-- Settings / home screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MemoWidget.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Quick-entry edit screen, launched from widget, MainActivity, and the
            note list via explicit Intent(context, EditActivity::class.java).
            Sec-1 / M3: was previously exported=true with a public
            `dev.aria.memo.EDIT` action filter, which let any third-party app
            start EditActivity with arbitrary EXTRA_BODY / EXTRA_PATH and write
            into the user's GitHub repo. No in-app caller uses the action
            filter (all call sites build explicit intents), so we lock the
            activity down to same-process callers only.
        -->
        <activity
            android:name=".EditActivity"
            android:exported="false"
            android:label="@string/edit_title"
            android:launchMode="singleTop"
            android:theme="@style/Theme.MemoWidget" />

        <!-- Glance-backed AppWidget receiver — quick memo 2x2 -->
        <receiver
            android:name=".widget.MemoWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/memo_widget_info" />
        </receiver>

        <!-- Event reminder alarm receiver (explicit component, not registered via intent-filter). -->
        <receiver
            android:name=".notify.EventAlarmReceiver"
            android:exported="false" />

        <!--
            Re-arm AlarmManager alarms + repaint widgets on:
              - device boot (BOOT_COMPLETED)
              - APK upgrade / sideload (MY_PACKAGE_REPLACED) — alarms cleared
              - phone timezone change (TIMEZONE_CHANGED) — alarms still fire
                but at the wrong wall-clock time, widget date label drifts
              - Android 14+ user toggling "Alarms & reminders" permission
                (SCHEDULE_EXACT_ALARM_PERMISSION_STATE_CHANGED) — system
                downgrades exact → inexact (or back), so we re-arm everything
                with the new permission state in mind

            Fix-WP (Review-Q): the original filter only listened for
            BOOT_COMPLETED, so each of the other three events silently dropped
            every scheduled alarm until the user next opened the app.
            SCHEDULE_EXACT_ALARM_PERMISSION_STATE_CHANGED is API 33+ but the
            string is harmless on older versions — it just never fires.
        -->
        <receiver
            android:name=".notify.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.SCHEDULE_EXACT_ALARM_PERMISSION_STATE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Glance-backed AppWidget receiver — today list 4x2 -->
        <receiver
            android:name=".widget.TodayWidgetReceiver"
            android:exported="true"
            android:label="@string/today_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_widget_info" />
        </receiver>

        <!--
            Fix-X3 / Review-X #4 — 跨日 BDD 漏洞修复。
            AppWidget 进程默认不订阅 ACTION_DATE_CHANGED；TodayWidget.provideGlance
            内部用 LocalDate.now() 决定"今天"，跨日（00:00）后 widget 会卡在"昨天"
            直到下一次 APPWIDGET_UPDATE tick 或数据写路径触发刷新。
            DateChangedReceiver 监听 system 的 DATE_CHANGED / TIME_SET /
            TIMEZONE_CHANGED 三个 action，瞬时调用 WidgetRefresher.refreshAll。
            exported=false：广播发送方只能是系统本身，第三方 app 无法伪造。
        -->
        <receiver
            android:name=".widget.DateChangedReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
